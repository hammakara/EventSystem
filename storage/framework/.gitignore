# =============================================================================
# Storage/Framework Directory - .gitignore
# =============================================================================
# This directory contains Laravel framework cache files, compiled views,
# and other temporary files generated by Laravel during execution.
# These files are automatically generated and should not be in version control.
# =============================================================================

# Compiled PHP files and cached configurations
compiled.php        # Compiled PHP code for optimization
config.php          # Cached configuration file
down                # Maintenance mode file
events.scanned.php  # Cached event listeners
maintenance.php     # Maintenance mode configuration
routes.php          # Cached routes file
routes.scanned.php  # Scanned routes cache
schedule-*          # Scheduled task mutex files
services.json       # Cached service providers
